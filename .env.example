# Optional: without this key, the game runs in demo engine mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional. Generates a new scene image only when the location changes.
# This uses paid OpenAI image generation. Keep false while testing text only.
ENABLE_IMAGE_GENERATION=false
OPENAI_IMAGE_MODEL=gpt-image-1

# Optional: enables durable server-side campaigns through Supabase.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
