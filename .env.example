# Mestre de Jogo textual. Failover automático: Groq -> Gemini -> OpenAI.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_GENERATIVE_AI_MODEL=gemini-3.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Opcional. Se vazio, usa 8s Groq, 10s Gemini e 12s OpenAI.
NARRATIVE_PROVIDER_TIMEOUT_MS=
NARRATIVE_CIRCUIT_COOLDOWN_MS=120000

# Banco visual híbrido. Sem chave, o jogo usa cache/fallback e nunca bloqueia o turno.
IMAGE_GENERATION_ENABLED=true
IMAGE_API_KEY=
IMAGE_MODEL=gpt-image-2
IMAGE_ESTIMATED_COST_USD=0

# Biblioteca visual global incremental.
BLOB_READ_WRITE_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
GLOBAL_VISUAL_DAILY_LIMIT_PER_CAMPAIGN=4
